# Copy to .env on the staging or production host, then replace every placeholder.
# Do not commit the rendered .env file.

# PostgreSQL
POSTGRES_USER=smrit_user
POSTGRES_PASSWORD=<generate-strong-postgres-password>
POSTGRES_DB=smrit_fms

# Redis
REDIS_PASSWORD=<generate-strong-redis-password>

# Traccar database and admin account
TRACCAR_DB_HOST=postgres
TRACCAR_DB_PORT=5432
TRACCAR_DB_NAME=traccar_gps
TRACCAR_DB_USER=traccar_user
TRACCAR_DB_PASSWORD=<generate-strong-traccar-db-password>
TRACCAR_ADMIN_EMAIL=<production-traccar-admin-email>
TRACCAR_ADMIN_PASSWORD=<generate-strong-traccar-admin-password>
TRACCAR_URL=http://traccar:8082
TRACCAR_OSMAND_ENDPOINT=https://<your-domain>/gps/

# Backend
NODE_ENV=production
PORT=3016
JWT_SECRET=<generate-64-plus-character-random-secret>
CORS_ORIGIN=https://<your-domain>

# React dashboard build
VITE_API_URL=https://<your-domain>/api
